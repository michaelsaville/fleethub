# ─── Database ──────────────────────────────────────────────────────────────
# Shares the dochub Postgres instance via the `fleethub` schema.
DATABASE_URL=postgresql://dochub:CHANGE_ME@db:5432/dochub?schema=fleethub

# ─── NextAuth ──────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://fleethub.pcc2k.com
NEXTAUTH_SECRET=GENERATE_WITH_openssl_rand_-base64_32

# ─── Entra SSO (shared with DocHub + OpsHub — same app reg) ───────────────
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=

# ─── Cross-app BFF (Phase 1+) ──────────────────────────────────────────────
TICKETHUB_BASE_URL=https://tickethub.pcc2k.com
FL_BFF_SECRET=GENERATE_WITH_openssl_rand_-hex_32

# ─── Inbound (Phase 2+ — agent → FleetHub) ─────────────────────────────────
FLEETHUB_AGENT_SECRET=GENERATE_WITH_openssl_rand_-hex_32
