// FleetHub Prisma Schema
// Shares the existing dochub Postgres database with TicketHub, DocHub, OpsHub.
// All models prefixed Fl_ and live in the `fleethub` schema.
// Schema is additive only after first push — never rename or drop columns.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["fleethub"]
}

// ─── STAFF GATE ────────────────────────────────────────────────────────────

/// Per-app email allowlist for FleetHub access. Mirrors OpsHub's pattern;
/// intentionally separate so junior tech can have OpsHub access without
/// FleetHub access (or vice-versa).
model Fl_StaffUser {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("TECH") // ADMIN | TECH | VIEWER
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Per-staff saved views (column orderings, dashboard layouts, alert
  // filters). JSON blob keyed by view-id; UI saves whenever a tech
  // resizes a column or rearranges a widget. Per UI-PATTERNS.md, all
  // list state must persist — retrofitting it later is expensive.
  savedViewsJson String?

  @@map("fl_staff_users")
  @@schema("fleethub")
}

// ─── AUDIT LOG ─────────────────────────────────────────────────────────────

/// Append-only privileged-action log. Hash-chained per HIPAA-READY.md.
/// Drives the activity-log component on every detail page.
///
/// `prevHash` + `rowHash` form the chain: rowHash = SHA-256 of
/// (prevHash || actor || action || target || createdAt || detailJson).
/// Tampering with any historical row breaks the chain — verify on demand
/// via /api/audit/verify endpoint (Phase 1+).
///
/// Database role MUST be REVOKEd from DELETE/UPDATE on this table at
/// deploy time (Phase 1 deploy task).
model Fl_AuditLog {
  id            String   @id @default(cuid())
  actorEmail    String?
  /// Cross-app key (matches TH_Client.name; OpsHub Op_AuditLog uses same).
  clientName    String?
  /// Target host/device identifier (Fl_Device.id, hostname, or null for
  /// non-host actions like "client.connected").
  deviceId      String?
  /// Verb in dotted form: "agent.command.run", "patch.deploy.queued",
  /// "script.execute", "remote.session.opened", etc.
  action        String
  outcome       String  // "ok" | "error" | "pending"
  detailJson    String?
  prevHash      String?
  rowHash       String?
  createdAt     DateTime @default(now())

  @@index([clientName, createdAt])
  @@index([deviceId, createdAt])
  @@index([action, createdAt])
  @@map("fl_audit_log")
  @@schema("fleethub")
}

// ─── DEVICES ───────────────────────────────────────────────────────────────

/// One row per host an agent connects from. Phase 1 fills basics
/// (hostname, OS, last seen); Phases 2-5 add inventory/patch/script
/// state (likely as JSON blobs on this row, plus dedicated tables for
/// time-series).
model Fl_Device {
  id            String    @id @default(cuid())
  /// Cross-app key — matches TH_Client.name.
  clientName    String
  hostname      String
  os            String?   // "windows" | "linux" | "darwin"
  osVersion     String?
  /// Free-form: "DC", "workstation", "server", "laptop". Set by tech.
  role          String?
  ipAddress     String?
  /// FK to Op_Agent.id once an agent enrolls. Null until enrollment.
  agentId       String?
  isOnline      Boolean   @default(false)
  lastSeenAt    DateTime?
  /// Last hardware/software inventory snapshot — JSON blob, normalized
  /// into separate tables in Phase 1 if/when query needs surface.
  inventoryJson String?
  isActive      Boolean   @default(true)
  // Phase 3 — Maintenance Mode (NinjaOne-style toggle).
  // When true, software.* and patches.* commands are NOT dispatched and
  // alerts from this host are tagged suppressed. Walk-away-safe for
  // clinical procedure windows. See PHASE-3-DESIGN §7.
  maintenanceMode      Boolean   @default(false)
  maintenanceUntil     DateTime?
  maintenanceReason    String?
  maintenanceSetBy     String?
  // Phase 3 — set true when a deploy returned reboot-deferred.
  // Drained on next compatible window or explicit "Reboot now".
  pendingReboot        Boolean   @default(false)
  pendingRebootSince   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([clientName, hostname])
  @@index([clientName, isOnline])
  @@index([os])
  @@index([maintenanceMode])
  @@map("fl_devices")
  @@schema("fleethub")
}

/// Per-tenant config singleton (FleetHub is single-tenant today, but
/// hipaaMode + signing keys + protected processes need a per-tenant
/// home so we don't have to re-seam later). One row per `clientName`
/// that we manage.
model Fl_Tenant {
  id                          String   @id @default(cuid())
  /// Matches TH_Client.name + Fl_Device.clientName.
  name                        String   @unique
  /// HIPAA mode flips: signed-script-only enforcement, signed-body
  /// enforcement on custom packages, dry-run-by-default-with-MFA.
  hipaaMode                   Boolean  @default(false)
  /// JSON array of base64 Ed25519 public keys. Multi-key for rotation.
  /// Used by agent to verify both Fl_Script.bodyEd25519Sig and
  /// Fl_Package.bodyEd25519Sig. See PHASE-2-DESIGN §3 + PHASE-3-DESIGN §11.
  scriptPublicKeysJson        String?
  /// JSON array of process basenames. When agent considers
  /// rebootPolicy=defer-if-user-active, presence of any of these
  /// processes blocks reboot regardless of console-session state.
  /// Default for healthcare: ["Dentrix.exe","eClinical*.exe","Eaglesoft*.exe"].
  protectedProcessNamesJson   String?
  defaultRingId               String?  // FK to Fl_DeployRing
  defaultPackageRebootPolicy  String   @default("defer-if-user-active")

  // Phase 5 — per-tenant report branding.
  /// Logo for the report PDF cover. Path under /api/uploads/...
  reportLogoUrl       String?
  /// Hex accent color used in PDF section dividers + headline numbers.
  reportAccentColor   String  @default("#F97316")
  /// Optional footer text on every PDF page (compliance disclaimer, etc).
  reportFooterText    String?
  /// Days to retain generated artifacts. HIPAA default = 6 * 365.
  reportRetentionDays Int     @default(2190)
  /// Phase 5.5 — opt-in Claude API hook for QBR cover-page narrative.
  qbrAutoNarrative    Boolean @default(false)
  /// Phase 5.5 — Scout integration; lets Identity Posture report pull
  /// the latest IdentityAuditResults for this tenant from the Scout app.
  scoutTenantId       String?

  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@map("fl_tenants")
  @@schema("fleethub")
}

// ─── ALERTS ────────────────────────────────────────────────────────────────

/// Active and historical alerts. Each row is one event in a host's
/// timeline. Resolved alerts kept for 6+ years per HIPAA retention.
model Fl_Alert {
  id            String    @id @default(cuid())
  clientName    String
  deviceId      String?
  /// "ok->fail" transition that fired this alert: "disk.full",
  /// "service.down", "patch.failed", "agent.disconnected", etc.
  kind          String
  severity      String    // "info" | "warn" | "critical"
  title         String
  /// Optional machine-readable payload (e.g. service name + state).
  detailJson    String?
  state         String    @default("open") // "open" | "ack" | "resolved"
  ackedBy       String?
  ackedAt       DateTime?
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([clientName, state, createdAt])
  @@index([deviceId, state])
  @@index([severity, state])
  @@map("fl_alerts")
  @@schema("fleethub")
}

// ─── SCRIPTS ───────────────────────────────────────────────────────────────

/// Script library — the "ComStore but curated" per UI-PATTERNS.md.
/// Each script is hash-pinned: signedHash is what the agent verifies
/// before execution. Editing a script creates a new revision; old
/// revisions retained for audit.
model Fl_Script {
  id            String   @id @default(cuid())
  /// Display name shown in the library.
  name          String
  /// "powershell" | "bash" | "batch".
  shell         String
  description   String?
  category      String?  // "maintenance" | "diagnostics" | "remediation" | ...
  tagsJson      String?  // ["disk", "windows", "remediation"]
  body          String   @db.Text
  /// SHA-256 of body, signed by an admin. Agent verifies before run.
  /// Per HIPAA-READY signed-script-only enforcement.
  signedHash    String
  signedBy      String?
  signedAt      DateTime?
  /// Whether this is in the "curated" set (visible in default library)
  /// or a private/draft script (only visible to creator). Curation gate
  /// per UI-PATTERNS — quality > quantity.
  isCurated     Boolean  @default(false)
  isActive      Boolean  @default(true)
  // Phase 2 additions (PHASE-2-DESIGN §9):
  /// Detached Ed25519 sig over signedHash by the tenant compliance key.
  /// Required when any tenant has hipaaMode=true.
  bodyEd25519Sig          String?
  /// SHA-256 of the body bytes. Recomputed by agent at exec time.
  bodySha256              String?
  /// HIPAA tenants enforce this; toggle for non-HIPAA "draft" scripts.
  requiresSignature       Boolean  @default(true)
  /// Some scripts can't honor dry-run (one-shot remediation, irreversible).
  /// When false, the run UI greys out the "apply" path entirely.
  dryRunCapable           Boolean  @default(true)
  /// e.g. "-WhatIf" (PowerShell) or "--dry-run" (bash). Passed as first
  /// arg by agent when dryRun=true.
  dryRunArg               String?
  /// JSON array of CAP_* names (Linux) the agent grants to the script
  /// child process. Empty = unprivileged.
  capabilitiesJson        String?
  /// JSON array of SeXxxPrivilege names (Windows JobObject).
  windowsPrivilegesJson   String?
  /// PHI-aware logging: when true, output may contain file content;
  /// agent only uploads transcript when tenant has explicit opt-in.
  outputContainsContent   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category, isCurated])
  @@map("fl_scripts")
  @@schema("fleethub")
}

// ─── SCRIPT EXECUTIONS ─────────────────────────────────────────────────────

/// History of script runs. One row per (script, target host) pair.
/// Drives the "recent activity" cards on device detail pages.
/// Phase 2 doubles this row as the dispatcher state machine (per
/// PHASE-2-DESIGN, deviation: original spec'd separate Fl_ScriptCommand
/// + Fl_ScriptRunOutput tables, merged here for simplicity).
model Fl_ScriptRun {
  id            String    @id @default(cuid())
  scriptId      String
  deviceId      String
  /// Tech who initiated; null for cron/scheduled runs.
  initiatedBy   String?
  /// "queued" | "running" | "ok" | "error" | "timeout" | "cancelled" | "dryrun" | "rejected"
  state         String    @default("queued")
  /// stdout from agent (truncated to 64KB; full output in object storage).
  output        String?   @db.Text
  /// Phase 2: stderr capture, separate from stdout for deploy-monitor-style
  /// inline error display.
  stderr        String?   @db.Text
  exitCode      Int?
  /// Was this a dry run? Defaults true per HIPAA-READY.md; tech opts in.
  dryRun        Boolean   @default(true)
  // Phase 2 dispatch fields (PHASE-2-DESIGN §2 + §9):
  /// JSON: stringly-typed args passed to interpreter (quoted by agent).
  argsJson      String?
  /// JSON: additional env vars (CommonName, Tenant, etc.).
  envJson       String?
  /// Hard kill at this point (default 300s).
  timeoutSec    Int?
  /// Total bytes captured (any cap). When > inline cap, full transcript
  /// at outputUrl.
  outputBytes   Int?
  /// S3-compatible URL when output exceeds inline cap.
  outputUrl     String?
  /// SHA-256 of full transcript (any size).
  outputSha256  String?
  /// Reason if state=rejected ("script-sig-invalid", "script-body-tampered",
  /// "agent-offline", "device-maintenance-mode", etc.)
  rejectReason  String?
  durationMs    Int?
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([deviceId, createdAt])
  @@index([scriptId, createdAt])
  @@index([state])
  @@map("fl_script_runs")
  @@schema("fleethub")
}

// ─── PHASE 3: SOFTWARE DEPLOYMENT ──────────────────────────────────────────

/// Catalog row. One per (tenant, package, OS) — Windows Chrome and
/// macOS Chrome are separate rows. Sources (winget/choco/brew/custom)
/// federate behind the row so the deploy UI doesn't fork by source.
/// See PHASE-3-DESIGN §3.
model Fl_Package {
  id              String   @id @default(cuid())
  tenantName      String   // Fl_Tenant.name
  name            String   // "Google Chrome"
  category        String?  // "browser" | "office" | "security" | "vertical" | …
  source          String   // "winget" | "choco" | "brew" | "custom"
  sourceId        String   // winget pkg id, choco id, brew formula, or "custom:<id>"
  os              String   // "windows" | "macos" | "linux" | "any"
  scope           String   @default("machine")  // "machine" | "user"
  dryRunCapable   Boolean  @default(true)
  /// "never" | "defer-if-user-active" | "force" | "schedule-window"
  rebootPolicy    String   @default("defer-if-user-active")
  /// HIPAA tenants enforce; agent verifies before install.
  signedBody      Boolean  @default(false)
  bodySha256      String?
  bodyEd25519Sig  String?
  /// Vendor metadata parsed at upload (custom MSI/PKG only):
  /// { productCode, upgradeCode, productVersion, bundleId, … }
  vendorMetadataJson String?
  /// Suggested at custom-MSI upload time; editable.
  silentInstallArgs   String?
  silentUninstallArgs String?
  /// JSON: detection rule (see PHASE-3-DESIGN §3.2).
  detectionRuleJson   String?
  isApproved      Boolean  @default(false) // operator must approve before deploy
  archivedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  versions        Fl_PackageVersion[]
  deployments     Fl_Deployment[]

  @@index([tenantName, archivedAt, name])
  @@index([source, sourceId])
  @@map("fl_packages")
  @@schema("fleethub")
}

/// Per-version row. Version pinning + custom-MSI artifact storage live here.
model Fl_PackageVersion {
  id                String   @id @default(cuid())
  packageId         String
  package           Fl_Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
  version           String   // "122.0.6261.95"; vendor format, not parsed
  releaseDate       DateTime?
  /// Custom packages only: where the agent fetches the artifact.
  artifactUrl       String?
  artifactSha256    String?
  /// Server-pinned default for new deploys.
  isApprovedDefault Boolean  @default(false)
  createdAt         DateTime @default(now())

  @@unique([packageId, version])
  @@index([packageId, isApprovedDefault])
  @@map("fl_package_versions")
  @@schema("fleethub")
}

/// Update Ring. Per-tenant rollout shape (Action1 pattern).
/// Stages JSON (PHASE-3-DESIGN §5):
///   [{ name, selectorKind, selectorValue, abortFailureRate,
///      autoPromoteAfterSec, requiresApproval }, …]
model Fl_DeployRing {
  id              String   @id @default(cuid())
  tenantName      String
  name            String   // "Standard 4-stage", "Healthcare conservative"
  stagesJson      String   @db.Text
  isDefault       Boolean  @default(false)
  archivedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deployments     Fl_Deployment[]

  @@index([tenantName, isDefault])
  @@map("fl_deploy_rings")
  @@schema("fleethub")
}

/// One deployment = one (package, version, action, ring) execution.
/// Targets are spread across stages defined by the ring.
model Fl_Deployment {
  id                  String   @id @default(cuid())
  tenantName          String
  packageId           String
  package             Fl_Package @relation(fields: [packageId], references: [id])
  packageVersionId    String
  ringId              String
  ring                Fl_DeployRing @relation(fields: [ringId], references: [id])
  /// "install" | "uninstall" | "update"
  action              String
  /// "queued" | "running" | "paused" | "auto-paused" | "completed" | "aborted"
  status              String   @default("queued")
  dryRun              Boolean  @default(true)
  /// Optional override. Null = use Fl_Package.rebootPolicy.
  rebootPolicyOverride String?
  scheduledFor        DateTime?
  startedAt           DateTime?
  completedAt         DateTime?
  pausedAt            DateTime?
  pauseReason         String?
  requestedBy         String   // operator email
  totalTargets        Int      @default(0)
  succeededCount      Int      @default(0)
  failedCount         Int      @default(0)
  noOpCount           Int      @default(0)
  pendingCount        Int      @default(0)
  rebootDeferredCount Int      @default(0)
  /// Stage we're currently dispatching (or last completed stage if paused).
  currentStage        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  targets             Fl_DeploymentTarget[]

  @@index([tenantName, status, createdAt])
  @@index([packageId, createdAt])
  @@map("fl_deployments")
  @@schema("fleethub")
}

/// One Fl_DeploymentTarget = one host slice of one Fl_Deployment.
model Fl_DeploymentTarget {
  id                  String   @id @default(cuid())
  deploymentId        String
  deployment          Fl_Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  deviceId            String
  stageName           String   // matches Fl_DeployRing.stagesJson[].name
  /// "pending" | "dispatched" | "running" | "succeeded" | "failed"
  ///   | "no-op" | "reboot-deferred" | "skipped"
  status              String   @default("pending")
  attemptCount        Int      @default(0)
  exitCode            Int?
  durationMs          Int?
  detectedVersionPre  String?
  detectedVersionPost String?
  /// Last 4 KiB of stderr — inline so deploy monitor doesn't drill.
  stderrTail          String?  @db.Text
  /// Last status message from agent ("Downloading 12.4 / 18.6 MB").
  progressMessage     String?
  progressPercent     Int?
  outputUrl           String?  // S3 if exceeded inline cap
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([deploymentId, status])
  @@index([deviceId, createdAt])
  @@map("fl_deployment_targets")
  @@schema("fleethub")
}

// ─── PHASE 4: PATCH MANAGEMENT ─────────────────────────────────────────────

/// Patch catalog row. Global per (source, sourceId) — catalog is shared
/// across tenants (KB5036893 is the same patch everywhere). Per-tenant
/// approval lives on the row for v1; multi-tenant approval needs a
/// separate Fl_PatchApproval table — Phase 4.5 deviation.
/// See PHASE-4-DESIGN §3.
model Fl_Patch {
  id                String   @id @default(cuid())
  /// "ms" | "thirdparty" | "custom"
  source            String
  /// "KB5036893" / "Adobe.Acrobat.DC@..." / "custom:<id>"
  sourceId          String
  os                String   // "windows" | "macos" | "linux" | "any"
  title             String
  /// "security" | "critical" | "definition" | "feature" | "rollup"
  /// | "driver" | "third-party"
  classification    String
  /// JSON: ["CVE-2026-XXXX", ...]. Empty for non-security.
  cveJson           String?
  /// Highest CVSS v3.1 base score across cveJson. 0-10.
  cvssMax           Float?
  /// CISA Known Exploited Vulnerabilities. Bumps priority hard.
  isKev             Boolean  @default(false)
  /// Server 2025 / Win 11 hotpatch — install without reboot.
  isHotpatch        Boolean  @default(false)
  requiresReboot    Boolean?
  /// JSON: array of Fl_Patch.id strings this patch supersedes.
  supersedesIdsJson String?
  /// Custom only: artifact + sig + detection.
  artifactUrl       String?
  artifactSha256    String?
  bodyEd25519Sig    String?
  /// JSON detection rule (PHASE-4-DESIGN §5.3)
  detectionRuleJson String?
  /// "approved" | "declined" | "needs-approval" | "deferred" | "auto-declined"
  approvalState     String   @default("needs-approval")
  approvedBy        String?
  approvedAt        DateTime?
  notes             String?
  publishedAt       DateTime?
  ingestedAt        DateTime @default(now())
  updatedAt         DateTime @updatedAt
  installs          Fl_PatchInstall[]

  @@unique([source, sourceId])
  @@index([approvalState, isKev, cvssMax])
  @@index([os, classification])
  @@map("fl_patches")
  @@schema("fleethub")
}

/// CVE/advisory metadata. Hourly cron pulls NVD JSON 2.0 + CISA KEV.
/// Linked to patches via Fl_Patch.cveJson string-array (denormalized
/// for fast read; ingest cron is the keeper of consistency).
model Fl_PatchAdvisory {
  id           String   @id @default(cuid())
  cveId        String   @unique  // "CVE-2026-XXXX"
  cvssBase     Float?
  cvssVector   String?
  isKev        Boolean  @default(false)
  kevAddedAt   DateTime?
  /// Vendor named in the CISA KEV catalog ("Microsoft", "Adobe", ...)
  vendor       String?
  product      String?
  description  String?  @db.Text
  /// Recommendations from CISA KEV when present.
  ransomwareUseKnown Boolean @default(false)
  publishedAt  DateTime?
  /// JSON: ["confidentiality","integrity","availability"]
  impactJson   String?
  ingestedAt   DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isKev, cvssBase])
  @@index([kevAddedAt])
  @@map("fl_patch_advisories")
  @@schema("fleethub")
}

/// Per-host per-patch state. Real population happens via patches.scan
/// + patches.detect agent calls. v1 ships with mock-seeded rows so
/// the Vulnerable dashboard renders against real-shaped data.
/// See PHASE-4-DESIGN §12.
model Fl_PatchInstall {
  id                  String   @id @default(cuid())
  deviceId            String
  patchId             String
  patch               Fl_Patch @relation(fields: [patchId], references: [id], onDelete: Cascade)
  /// "installed" | "missing" | "failed" | "superseded" | "declined"
  /// | "preflight-failed" | "rollback-failed" | "detection-disagreement"
  state               String
  /// Per-method detection result. Null when method wasn't run.
  /// Cross-check on Windows for the "agent says yes, OS says no" case.
  wmiQfe              Boolean?
  dismPackages        Boolean?
  wuHistory           Boolean?
  lastDetectedAt      DateTime
  /// Deployment that put this patch on the host (when known).
  installingDeploymentId String?
  installedAt         DateTime?
  failureReason       String?
  /// Free-text from the agent (DISM error, wusa exit code, etc).
  rawDetail           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([deviceId, patchId])
  @@index([state, lastDetectedAt])
  @@index([deviceId, state])
  @@map("fl_patch_installs")
  @@schema("fleethub")
}

/// Saved target group. Created from the deploy form's
/// "Save these targets as a Group" inline action, or manually on /groups.
model Fl_DeviceGroup {
  id                String   @id @default(cuid())
  tenantName        String
  name              String
  /// Dynamic membership (RQL fragment). Re-evaluated at use time.
  rql               String?
  /// Static membership (JSON: array of Fl_Device.id strings).
  pinnedDeviceIdsJson String?
  createdBy         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantName, name])
  @@map("fl_device_groups")
  @@schema("fleethub")
}

// ─── PHASE 5: REPORTS ──────────────────────────────────────────────────────

/// One generated report artifact. Operator-initiated rows arrive in
/// state="queued" and the render worker (today: synchronous in the
/// generate API route) drives them through generating → ready. Scheduled
/// generation (Fl_ReportSchedule) is Phase 5.5; v1 is ad-hoc only.
model Fl_Report {
  id             String   @id @default(cuid())
  /// "patch-compliance" | "software-inventory" | "performance-trend"
  /// | "identity-posture" | "qbr"
  kind           String
  tenantName     String
  /// "tech" | "client" | "auditor" — toggles which sections render.
  audience       String   @default("client")
  /// Inclusive ISO date range. Some reports are point-in-time
  /// snapshots (asOf); others are intervals (start..end).
  asOf           DateTime?
  startDate      DateTime?
  endDate        DateTime?
  /// "pdf" | "csv" | "json" | "evidence-zip"
  format         String   @default("pdf")
  /// Local filesystem path under /uploads/reports/ for v1; S3-compatible
  /// URL once the storage swap-out lands. Null until state=ready.
  artifactUrl    String?
  artifactSha256 String?
  artifactBytes  Int?
  /// Generation context — cron schedule id (when scheduled) or
  /// operator email (when ad-hoc).
  generatedBy    String
  scheduleId     String?
  /// "queued" | "generating" | "ready" | "delivered" | "failed" | "expired"
  state          String   @default("queued")
  failureReason  String?
  /// state="expired" + artifactUrl cleared after this date. Defaults
  /// derive from Fl_Tenant.reportRetentionDays at create time.
  retentionUntil DateTime
  generatedAt    DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime @default(now())

  @@index([tenantName, kind, createdAt])
  @@index([state, retentionUntil])
  @@map("fl_reports")
  @@schema("fleethub")
}

/// Per-host aggregated performance samples. Agent's existing
/// inventory.report push (every 15min) feeds the row-level columns; a
/// server-side cron rolls 15-min samples → 1h, 1h → 1d, 1d → 7d.
/// Tier retention: 1h kept 30d, 1d kept 13mo, 7d kept 6 years.
model Fl_PerformanceSample {
  id               String   @id @default(cuid())
  deviceId         String
  /// Aggregation window. "1h" | "1d" | "7d"
  window           String
  /// Window start (inclusive). UTC.
  windowStart      DateTime
  cpuAvgPct        Float
  cpuP95Pct        Float
  ramAvgPct        Float
  ramP95Pct        Float
  diskUsedPct      Float
  /// Network bytes-in/out summed across interfaces.
  netInBytes       BigInt   @default(0)
  netOutBytes      BigInt   @default(0)
  uptimeSec        BigInt   @default(0)
  /// Count of agent.heartbeat misses in this window — gaps in
  /// monitoring affect report confidence.
  missedHeartbeats Int      @default(0)
  createdAt        DateTime @default(now())

  @@unique([deviceId, window, windowStart])
  @@index([window, windowStart])
  @@map("fl_performance_samples")
  @@schema("fleethub")
}
